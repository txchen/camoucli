{
  "name": "camoucli",
  "version": "0.1.0",
  "description": "CLI and local daemon for driving Camoufox through Playwright",
  "type": "module",
  "bin": {
    "camoucli": "./dist/cli/main.js",
    "camoucli-daemon": "./dist/daemon/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx src/cli/main.ts",
    "dev:daemon": "tsx src/daemon/main.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "extract-zip": "^2.0.1",
    "playwright-core": "1.51.1",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
